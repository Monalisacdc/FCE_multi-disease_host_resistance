library(dplyr)
library(sf)
library(leaflet)
library(ggplot2)
library(htmltools)
# ----------------------------------------
# Convert monitoring table into sf points
# ----------------------------------------
make_points_sf <- function(df) {
st_as_sf(df, coords = c("lon", "lat"), crs = 4326, remove = FALSE)
}
# ----------------------------------------
# Summarize by county
# ----------------------------------------
summarize_by_county <- function(df) {
df |>
group_by(county) |>
summarise(
n_insects = sum(n_insects, na.rm = TRUE),
n_positive = sum(n_positive, na.rm = TRUE),
n_traps = n(),
.groups = "drop"
)
}
# ----------------------------------------
# Summarize by week
# ----------------------------------------
summarize_by_week <- function(df) {
df |>
group_by(week) |>
summarise(
total_insects = sum(n_insects, na.rm = TRUE),
total_positive = sum(n_positive, na.rm = TRUE),
total_traps = n(),
.groups = "drop"
) |>
arrange(week)
}
# ----------------------------------------
# Join county summaries to county polygons
# ----------------------------------------
join_counties <- function(counties_sf, summary_df) {
counties_sf |>
left_join(summary_df, by = "county")
}
# ----------------------------------------
# Popup text for trap points
# ----------------------------------------
make_popup <- function(df) {
paste0(
"<b>County:</b> ", df$county, "<br/>",
"<b>Responsible:</b> ", df$responsible, "<br/>",
"<b>Coordinates:</b> ", round(df$lat, 4), ", ", round(df$lon, 4), "<br/>",
"<b>Insects:</b> ", df$n_insects, "<br/>",
"<b>Positive:</b> ", df$n_positive
)
}
# ----------------------------------------
# Interactive trap map
# ----------------------------------------
trap_map <- function(points_sf) {
leaflet(points_sf) |>
addProviderTiles(providers$CartoDB.Positron) |>
addCircleMarkers(
lng = ~lon,
lat = ~lat,
radius = 7,
color = "#1B5E20",
weight = 1,
fillColor = "#2E7D32",
fillOpacity = 0.85,
popup = ~make_popup(points_sf)
) |>
addLegend(
position = "bottomright",
colors = "#2E7D32",
labels = "Trap",
title = "Legend"
)
}
# ----------------------------------------
# Choropleth map: insects by county
# ----------------------------------------
insect_map <- function(counties_joined) {
pal <- colorNumeric(
palette = c("#d9f0d3", "#a6d96a", "#fdae61", "#d7191c"),
domain = counties_joined$n_insects,
na.color = "#f0f0f0"
)
leaflet(counties_joined) |>
addProviderTiles(providers$CartoDB.Positron) |>
addPolygons(
fillColor = ~pal(n_insects),
fillOpacity = 0.8,
color = "#666666",
weight = 1,
popup = ~paste0(
"<b>County:</b> ", county, "<br/>",
"<b>Number of insects:</b> ", ifelse(is.na(n_insects), 0, n_insects), "<br/>",
"<b>Number of traps:</b> ", ifelse(is.na(n_traps), 0, n_traps)
)
) |>
addLegend(
pal = pal,
values = ~n_insects,
title = "Insects by county",
position = "bottomright"
)
}
# ----------------------------------------
# Choropleth map: positives by county
# ----------------------------------------
positive_map <- function(counties_joined) {
pal <- colorNumeric(
palette = c("#d9f0d3", "#fee08b", "#f46d43", "#a50026"),
domain = counties_joined$n_positive,
na.color = "#f0f0f0"
)
leaflet(counties_joined) |>
addProviderTiles(providers$CartoDB.Positron) |>
addPolygons(
fillColor = ~pal(n_positive),
fillOpacity = 0.8,
color = "#666666",
weight = 1,
popup = ~paste0(
"<b>County:</b> ", county, "<br/>",
"<b>Positive to pathogen:</b> ", ifelse(is.na(n_positive), 0, n_positive), "<br/>",
"<b>Number of traps:</b> ", ifelse(is.na(n_traps), 0, n_traps)
)
) |>
addLegend(
pal = pal,
values = ~n_positive,
title = "Positive by county",
position = "bottomright"
)
}
# ----------------------------------------
# Weekly trend chart: insects
# ----------------------------------------
insect_trend_plot <- function(df_week) {
ggplot(df_week, aes(x = week, y = total_insects, group = 1)) +
geom_line(linewidth = 1, color = "#2E7D32") +
geom_point(size = 3, color = "#2E7D32") +
geom_area(aes(y = total_insects), alpha = 0.15, fill = "#2E7D32") +
geom_text(
data = df_week |> dplyr::slice_tail(n = 1),
aes(label = total_insects),
vjust = -0.8,
color = "#2E7D32",
fontface = "bold"
) +
labs(
title = "Weekly trend of insects collected",
x = "Week",
y = "Insects"
) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold"),
axis.text.x = element_text(angle = 45, hjust = 1)
)
}
# ----------------------------------------
# Weekly trend chart: positives
# ----------------------------------------
positive_trend_plot <- function(df_week) {
ggplot(df_week, aes(x = week, y = total_positive, group = 1)) +
geom_line(linewidth = 1, color = "#C62828") +
geom_point(size = 3, color = "#C62828") +
geom_area(aes(y = total_positive), alpha = 0.15, fill = "#C62828") +
geom_text(
data = df_week |> dplyr::slice_tail(n = 1),
aes(label = total_positive),
vjust = -0.8,
color = "#C62828",
fontface = "bold"
) +
labs(
title = "Weekly trend of pathogen-positive samples",
x = "Week",
y = "Positive"
) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold"),
axis.text.x = element_text(angle = 45, hjust = 1)
)
}
