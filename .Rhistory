#remove linhas com na
dat2 <- dat_ready %>%
filter(
!is.na(yy),
!is.na(time),
!is.na(geno),
!is.na(env),
!is.na(unit)
)
#temp minimo por curva (gen x env)
min_points <- 5
dat2 <- dat2 %>%
group_by(unit) %>%
filter(n() >= min_points) %>%
ungroup()
m_equal <- bam(
yy ~
geno +                         # <- importante
s(time, k = 10) +
s(time, by = geno, k = 4) +    # <- usar by=
s(env, bs = "re"),
family   = betar(link = "logit"),
data     = dat2,
method   = "fREML",
gamma    = 1.6,
discrete = TRUE,
select   = TRUE)
summary(m_equal)
dat_ready$geno <- factor(dat_ready$geno)
dat_ready$env  <- factor(dat_ready$env)
dat_ready$time <- as.numeric(dat_ready$time)
summary(m_like)
install.packages("tigris")
library(tigris)
library(sf)
library(dplyr)
dir.create("data", showWarnings = FALSE)
# Optional: cache downloaded shapefiles locally
options(tigris_use_cache = TRUE)
# Download Kansas counties
counties_ks <- tigris::counties(
state = "KS",
cb = TRUE,
year = 2024
) |>
st_transform(4326) |>
rename(county = NAME) |>
select(county, GEOID, geometry)
# Save as GeoJSON
st_write(
counties_ks,
"data/kansas_counties.geojson",
delete_dsn = TRUE,
quiet = TRUE
)
cat("Saved file: data/kansas_counties.geojson\n")
