library(nlme)
library(mgcv)
dat_ready <- dat_ready %>%
mutate(
env = factor(env),
geno = factor(geno),
curve_id = factor(curve_id),
time = as.numeric(time))
m1 <- r4pde::compare_curves(
data          = dat_ready,
time          = "time",
response      = "y",
treatment     = "geno",
environment   = "env",
cluster_k     = 3,
show_progress = TRUE,
test_factor   = "ts_cl",
perm_unit     = "geno",
perm_strata   = "env",
k_smooth = 10,
k_env = 4,
k_trt = 4,
gamma = 1.6,
min_points = 5)
cols <- c("#3A7CA5", "#f7c841", "#C11C84")
p_curves <- plot_curves(m1) +
scale_color_manual(
values = cols,
labels = c( "MR", "MS", "AS")) +
scale_x_continuous(breaks = seq(0, 90, by = 10)) +
ylim(0,0.25) +
theme(legend.position = "top")
p_dend <- plot_dendrogram(m1) +
scale_color_manual(
values = cols,
labels = c( "MR", "MS", "AS")) +
scale_y_continuous(expand = expansion(mult = c(0.05, 0.2)))
p_curves | p_dend
p_curves | p_dend
